{% set links = [
  {
    label: 'Skip to main'|t('app'),
    url: '#main',
  },
  {
    label: 'Skip to sidebar'|t('app'),
    url: '#sidebar-container',
  },
  {
    label: 'Skip to content'|t('app'),
    url: '#content-container',
  },
] %}

{% for link in links %}
  {{ tag ('a', {
    text: link.label,
    href: link.url,
    class: 'skip-link skip-link--global btn',
  }) }}
{% endfor %}