{% extends '_components/fieldtypes/elementfieldsettings.twig' %}
{% import '_includes/forms.twig' as forms %}

{% block showUnpermittedFields %}
    {{ forms.lightswitchField({
        label: 'Show unpermitted sections'|t('app'),
        instructions: 'Whether to show sections that the user doesn’t have permission to view.'|t('app'),
        id: 'showUnpermittedSections',
        name: 'showUnpermittedSections',
        on: field.showUnpermittedSections,
    }) }}

    {{ forms.lightswitchField({
        label: 'Show unpermitted entries'|t('app'),
        instructions: 'Whether to show Entries the user doesn’t have permission to view, per the "View other users\' entries" permission.'|t('app'),
        id: 'showUnpermittedEntries',
        name: 'showUnpermittedEntries',
        on: field.showUnpermittedEntries,
    }) }}
{% endblock %}
